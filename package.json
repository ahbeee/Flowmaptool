{
  "name": "flowmaptool",
  "version": "0.1.0",
  "private": true,
  "description": "Flowmaptool Windows desktop app (Electron + React + TypeScript)",
  "author": "Mindatom",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack:win": "npm run build && electron-builder --win --x64 --dir",
    "dist:win": "npm run build && electron-builder --win --x64",
    "build:win": "npm run dist:win",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "lint": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "npm run build && playwright test",
    "test:all": "npm run lint && npm run test:unit && npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.54.2",
    "@types/node": "24.3.0",
    "@types/react": "18.3.24",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "31.7.7",
    "electron-builder": "25.1.8",
    "electron-vite": "2.3.0",
    "typescript": "5.6.3",
    "vite": "5.4.11",
    "vitest": "2.1.9"
  },
  "build": {
    "appId": "com.mindatom.flowmaptool",
    "productName": "Flowmaptool",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-${arch}-installer.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Flowmaptool"
    }
  }
}
