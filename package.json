{
  "name": "flowmaptool",
  "version": "0.1.0",
  "private": true,
  "description": "Flowmaptool Windows desktop app (Electron + React + TypeScript)",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "lint": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "npm run build && playwright test",
    "test:all": "npm run lint && npm run test:unit && npm run test:integration && npm run test:e2e"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.54.2",
    "@types/node": "24.3.0",
    "@types/react": "18.3.24",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "electron": "31.7.7",
    "electron-vite": "2.3.0",
    "typescript": "5.6.3",
    "vite": "5.4.11",
    "vitest": "2.1.9"
  }
}
